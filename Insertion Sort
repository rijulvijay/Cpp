// Insertion Sort: Build sorted array from left, inserting each element
// Time: O(n²) worst, O(n) best | Space: O(1) | Stable: Yes

#include <iostream>
using namespace std;

void insertionSort(int arr[], int n) {
    for (int i = 1; i < n; i++) {
        int key = arr[i];        // Element to be placed correctly
        int j = i - 1;           // Start comparing from left of key

        // Shift elements that are greater than 'key' one position right
        while (j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];  // Shift right
            j--;
        }

        arr[j + 1] = key;        // Insert key in correct position
    }
}

int main() {
    int arr[] = {12, 11, 13, 5, 6};
    int n = sizeof(arr) / sizeof(arr[0]);
    insertionSort(arr, n);
    // Output: 5 6 11 12 13
    return 0;
}
