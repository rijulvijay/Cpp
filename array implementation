#include<iostream>
using namespace std;

class Array{
	
	int N;
	int*array;
	public:
		Array(int N){
		this->N=N;
		}
		
		~Array(){
		delete[] array;
		}
	
		void createArray(){
			array = new int [N]();
						
		}
		
		void insertArray() {

        cout << "Enter " << N << " elements:\n";

        for(int i = 0; i < N; i++) {
            cin >> array[i];
        }
    }
		void deleteArray(int number){
		for(int i = 0; i < N; i++) {

		if(array[i]== number){
			array[i]= -1;
		break;
		}
		}
		}
		
		void printArray() const{
		for(int i=0; i<N; i++){
			cout<< array[i] <<" ";
		}
		}
	
};



int main(){
	int N;
	cout<< "N:";
	cin>> N;
	Array obj(N);
	obj.createArray();

    obj.insertArray();

    cout << "Array Elements: ";
	obj.printArray();
	

int deleteArray = 0;

    cout << "\nDelete data: ";
    cin >> deleteArray;

    obj.deleteArray(deleteArray);

    cout << "Updated Array: ";
    obj.printArray();
	
	
return 0;
}
