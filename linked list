#include<iostream>
using namespace std;

class LinkedList {
    struct NODE {
        int data;
        NODE *next;
        NODE(int value) {
            data = value;
            next = NULL;
        }
    };
    NODE *head;
public:

    LinkedList() {
        head = NULL;
    }

    ~LinkedList() {
        NODE *temp;
        while(head != NULL) {
            temp = head;
            head = head->next;
            delete temp;
        }
    }
    void insert(int value) {
        NODE *newNode = new NODE(value);
        if(head == NULL) {
            head = newNode;
        }
        else {
            NODE *temp = head;
            while(temp->next != NULL) {
                temp = temp->next;
            }
            temp->next = newNode;
        }
    }

    void display() {
        NODE *temp = head;
        while(temp != NULL) {
        cout << temp->data << " -> ";
        temp = temp->next;
        }
        cout << "NULL";
    }
};

int main() {
    LinkedList obj;
    obj.insert(10);
    obj.insert(20);
    obj.insert(30);
    cout << "Linked List:\n";
    obj.display();
    return 0;
}
